{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/documents/*",
      "/portfolio-assets/*",
      "/xp-assets/*",
      "/*.{js,css,json,ico,png,svg,jpg,jpeg,gif,webp,avif,txt,xml,webmanifest,pdf,mp3,wav}"
    ]
  },
  "mimeTypes": {
    ".js": "application/javascript",
    ".mjs": "application/javascript",
    ".mp3": "audio/mpeg",
    ".svg": "image/svg+xml"
  }
}
